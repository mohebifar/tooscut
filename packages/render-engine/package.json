{
  "name": "@tooscut/render-engine",
  "version": "0.1.0",
  "files": [
    "dist",
    "wasm"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/snapshot-tester.d.ts",
      "import": "./dist/testing/snapshot-tester.js"
    },
    "./testing/renderer": {
      "types": "./dist/testing/test-renderer.d.ts",
      "import": "./dist/testing/test-renderer.js"
    },
    "./testing/vitest": {
      "types": "./dist/testing/vitest-integration.d.ts",
      "import": "./dist/testing/vitest-integration.js"
    },
    "./wasm/compositor": {
      "types": "./wasm/compositor/compositor.d.ts",
      "import": "./wasm/compositor/compositor.js"
    },
    "./wasm/audio-engine/*": "./wasm/audio-engine/*",
    "./dist/worklet/*": "./dist/worklet/*"
  },
  "scripts": {
    "build": "tsc && pnpm build:worklet",
    "build:wasm": "cd ../../crates && ./build.sh",
    "build:worklet": "tsdown src/worklet/audio-engine.worklet.ts --format iife --out-dir dist/worklet --no-dts",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:browser:watch": "vitest --config vitest.browser.config.ts",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "mediabunny": "^1.31.0"
  },
  "devDependencies": {
    "@types/audioworklet": "^0.0.94",
    "@types/node": "^22.19.7",
    "@vitest/browser": "^3.0.0",
    "@webgpu/types": "^0.1.69",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "playwright": "^1.50.0",
    "tsdown": "^0.20.1",
    "typescript": "^5.8.0",
    "vitest": "^3.0.0"
  }
}
