{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxlint/configuration_schema.json",
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "eqeqeq": "error",
    "no-var": "error",
    "prefer-const": "warn"
  },
  "settings": {
    "react": {
      "runtime": "automatic"
    }
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    ".output",
    "public/wasm",
    "*.min.js",
    "crates"
  ]
}
