{
  "name": "tooscut",
  "version": "1.0.0",
  "private": true,
  "description": "NLE Video Editor",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:wasm": "cd crates && ./build.sh",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --type-aware --fix",
    "format": "oxfmt --write apps packages",
    "format:check": "oxfmt --check apps packages --no-error-on-unmatched-pattern",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "clean": "turbo clean && rm -rf node_modules"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.19.0",
  "devDependencies": {
    "oxfmt": "^0.27.0",
    "oxlint": "^1.1.0",
    "oxlint-tsgolint": "^0.11.4",
    "turbo": "^2.5.0"
  }
}
